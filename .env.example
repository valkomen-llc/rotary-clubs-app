# Base de datos (Postgres para producción, SQLite para local)
DATABASE_URL="postgresql://USUARIO:PASSWORD@HOST/DATABASE"

# Secreto para JWT
JWT_SECRET=tu_secreta_aqui

# URL de la API del Frontend (para CORS)
CLIENT_URL=http://localhost:5173

# Puerto del Servidor
PORT=5001

# API URL para el Frontend (Vite)
VITE_API_URL=http://localhost:5001/api

# ── Modelos de IA (al menos uno requerido para ProyectIA) ──────────────────────
# Google Gemini (recomendado — gratuito con límites generosos)
GEMINI_API_KEY=tu_gemini_api_key_aqui

# OpenAI (GPT-4o, GPT-4o Mini)
OPENAI_API_KEY=tu_openai_api_key_aqui

# Anthropic Claude (3.5 Sonnet, Haiku)
ANTHROPIC_API_KEY=tu_anthropic_api_key_aqui

# Mistral AI
MISTRAL_API_KEY=tu_mistral_api_key_aqui

# Clave para cifrar API Keys guardadas en BD (cualquier string seguro de 32 chars)
AI_KEY_SECRET=cambia_esto_por_un_string_secreto_32chars

# ── WhatsApp Cloud API (Meta) ───────────────────────────────────────────────────
# Obtener en: developers.facebook.com → Tu App → WhatsApp → API Setup
WA_PHONE_NUMBER_ID=           # ID del número de teléfono del negocio (ej. 123456789)
WA_WABA_ID=                   # WhatsApp Business Account ID
WA_ACCESS_TOKEN=              # System User Token permanente (no expira)
WA_VERIFY_TOKEN=rotary_webhook_secret_2026  # Token secreto para validar el webhook
WA_APP_ID=                    # Meta App ID (opcional)
WA_API_VERSION=v19.0          # Versión de la Graph API

# ── Content Studio (KIE.ai + Meta para Reels) ──────────────────────────────────
# KIE.ai genera los videos a partir de fotos
KIE_API_KEY=

# Meta App para OAuth de Instagram/Facebook Reels (puede reusar la app de WhatsApp)
META_APP_ID=
META_APP_SECRET=

# OAuth opcionales para futuras integraciones
TIKTOK_CLIENT_KEY=
GOOGLE_CLIENT_ID=

# URL pública absoluta de la app (usada por callbacks OAuth y webhook de KIE)
APP_URL=https://app.clubplatform.org

# Secret para autenticar los crons de Vercel
CRON_SECRET=
