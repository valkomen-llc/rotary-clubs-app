generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   // administrator (super_admin), club_admin, member
  clubId    String?
  club      Club?    @relation(fields: [clubId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Club {
  id          String   @id @default(uuid())
  name        String
  city        String?
  country     String?
  district    String?
  domain      String?  @unique
  subdomain   String?  @unique
  logo        String?
  description String?
  status      String   @default("active") // active, inactive
  users       User[]
  projects    Project[]
  posts       Post[]
  donations   Donation[]
  settings    Setting[]
  content     ContentSection[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Media {
  id        String   @id @default(uuid())
  filename  String
  url       String
  type      String   // image, document
  size      Int
  bucket    String?
  region    String?
  clubId    String?
  createdAt DateTime @default(now())
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  image       String?
  status      String   // active, completed, planned
  clubId      String
  club        Club     @relation(fields: [clubId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Post {
  id        String   @id @default(uuid())
  title     String
  content   String
  image     String?
  published Boolean  @default(false)
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Donation {
  id          String   @id @default(uuid())
  amount      Float
  currency    String   @default("USD")
  donorName   String?
  donorEmail  String?
  status      String   // pending, success, failed
  clubId      String?
  club        Club?    @relation(fields: [clubId], references: [id])
  date        DateTime @default(now())
}

model Setting {
  id        String   @id @default(uuid())
  key       String   
  value     String   @db.Text
  clubId    String?
  club      Club?    @relation(fields: [clubId], references: [id])
  updatedAt DateTime @updatedAt

  @@unique([key, clubId])
}

model ContentSection {
  id        String   @id @default(uuid())
  page      String   // home, about, etc.
  section   String   // hero, foundation, etc.
  content   String   @db.Text // JSON string with the section content
  clubId    String?
  club      Club?    @relation(fields: [clubId], references: [id])
  updatedAt DateTime @updatedAt
}
