generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String             @id @default(uuid())
  email              String             @unique
  password           String
  role               String
  clubId             String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  clubRole           String?
  emailVerified      Boolean            @default(false)
  name               String?
  phone              String?
  phoneCountry       String?
  verificationCode   String?
  verificationExpiry DateTime?
  districtId         String?
  uploadedDocuments  ClubDocument[]
  communicationLogs  CommunicationLog[]
  orders             Order[]
  club               Club?              @relation(fields: [clubId], references: [id])
  district           District?          @relation(fields: [districtId], references: [id])
}

model District {
  id            String   @id @default(uuid())
  number        Int?
  name          String
  governor      String?
  governorEmail String?
  countries     String[] @default([])
  website       String?
  subdomain     String?  @unique
  domain        String?  @unique
  description   String?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  logo          String?
  footerLogo    String?
  favicon       String?
  colors        Json?    @default("{\"primary\": \"#013388\", \"secondary\": \"#E29C00\"}")
  logoHeaderSize Int      @default(200)
  expirationBannerActive   Boolean                 @default(false)
  expirationBannerMessage  String?
  developmentBannerActive  Boolean                 @default(false)
  developmentBannerMessage String?
  subscriptionStatus       String                  @default("active")
  expirationDate           DateTime?
  stripeCustomerId         String?                 @unique
  billingContactEmail      String?
  billingContactPhone      String?
  lastNotificationSent     DateTime?
  notificationLevel        Int                     @default(0)
  clubs         Club[]
  admins        User[]
}

model Club {
  id                       String                  @id @default(uuid())
  name                     String
  city                     String?
  country                  String?
  district                 String?
  domain                   String?                 @unique
  subdomain                String?                 @unique
  logo                     String?
  footerLogo               String?
  endPolioLogo             String?
  description              String?
  status                   String                  @default("active")
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  favicon                  String?
  type                     String                  @default("club")
  organizationType         String                  @default("Club Rotario")
  districtId               String?
  expirationBannerActive   Boolean                 @default(false)
  expirationBannerMessage  String?
  developmentBannerActive  Boolean                 @default(false)
  developmentBannerMessage String?
  subscriptionStatus       String                  @default("active")
  expirationDate           DateTime?
  stripeCustomerId         String?
  billingContactEmail      String?
  billingContactPhone      String?
  lastNotificationSent     DateTime?
  notificationLevel        Int                     @default(0)
  events                   CalendarEvent[]
  affiliatedDistrict       District?               @relation(fields: [districtId], references: [id])
  documents                ClubDocument[]
  members                  ClubMember[]
  communicationLogs        CommunicationLog[]
  communicationTemplates   CommunicationTemplate[]
  content                  ContentSection[]
  donations                Donation[]
  exchangeHostFamilies     ExchangeHostFamily[]
  exchangeStudents         ExchangeStudent[]
  financialReports         FinancialReport[]
  fundingOpportunities     FundingOpportunity[]
  knowledge                KnowledgeSource[]
  Lead                     Lead[]
  ngseHostFamilies         NgseHostFamily[]
  ngseParticipants         NgseParticipant[]
  notificationConfigs      NotificationConfig[]
  orders                   Order[]
  payments                 Payment[]
  paymentConfigs           PaymentProviderConfig[]
  payouts                  PayoutRequest[]
  posts                    Post[]
  products                 Product[]
  categories               ProductCategory[]
  projects                 Project[]
  publications             Publication[]
  rotexMembers             RotexMember[]
  settings                 Setting[]
  socialAccounts           SocialAccount[]
  sponsoredClubs           SponsoredClub[]
  testimonials             Testimonial[]
  users                    User[]
  whatsAppCampaigns        WhatsAppCampaign[]
  whatsAppConfig           WhatsAppConfig?
  whatsAppContacts         WhatsAppContact[]
  whatsAppLists            WhatsAppContactList[]
  WhatsAppCustomField      WhatsAppCustomField[]
  whatsAppTemplates        WhatsAppTemplate[]
  technicalRequests         TechnicalRequest[]
  crowdfundPools            CrowdfundPool[]         @relation("ClubPools")
  emailAccounts             EmailAccount[]
}

model EmailAccount {
  id        String   @id @default(uuid())
  email     String   @unique
  label     String?
  password  String?
  isPrimary Boolean  @default(false)
  provider           String   @default("platform")
  verified           Boolean  @default(false)
  verificationStatus String   @default("pending")
  dnsRecords         Json?
  clubId             String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  club               Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
}

model CrowdfundPool {
  id           String   @id @default(uuid())
  clubId       String
  totalCapital Float
  costPerUnit  Float
  totalUnits   Int
  currency     String   @default("USD")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  club         Club     @relation("ClubPools", fields: [clubId], references: [id])
  activations  CrowdfundActivation[]
}

model CrowdfundActivation {
  id             String   @id @default(uuid())
  poolId         String
  targetClubId   String
  domainName     String?
  status         String   @default("active")
  activationDate DateTime @default(now())
  expirationDate DateTime?
  pool           CrowdfundPool @relation(fields: [poolId], references: [id])
}

model ClubDocument {
  id           String   @id @default(uuid())
  clubId       String
  fileName     String
  fileUrl      String
  s3Key        String
  fileType     String
  fileSize     Int
  category     String   @default("general")
  uploadedById String?
  createdAt    DateTime @default(now())
  club         Club     @relation(fields: [clubId], references: [id])
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
}

model Media {
  id        String   @id @default(uuid())
  filename  String
  url       String
  type      String
  size      Int
  bucket    String?
  region    String?
  clubId    String?
  createdAt DateTime @default(now())
  s3Key     String?
}

model Project {
  id              String     @id @default(uuid())
  title           String
  description     String
  image           String?
  status          String
  category        String?
  meta            Float?     @default(0)
  recaudado       Float?     @default(0)
  donantes        Int?       @default(0)
  beneficiarios   Int?       @default(0)
  ubicacion       String?
  fechaEstimada   DateTime?
  videoUrl        String?
  images          String[]
  impacto         String?
  actualizaciones String?
  clubId          String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?
  donations       Donation[]
  club            Club       @relation(fields: [clubId], references: [id])
}

model Post {
  id             String    @id @default(uuid())
  title          String
  content        String
  image          String?
  published      Boolean   @default(false)
  category       String?
  tags           String[]
  keywords       String?
  seoTitle       String?
  seoDescription String?
  videoUrl       String?
  images         String[]
  isAI           Boolean   @default(false)
  clubId         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  slug           String?   @unique
  seoImage       String?
  socialCopy     String?
  ctaCopy        String?
  videoGallery   String[]
  comments       Comment[]
  club           Club?     @relation(fields: [clubId], references: [id])
}

model Donation {
  id          String   @id @default(uuid())
  amount      Float
  currency    String   @default("USD")
  donorName   String?
  donorEmail  String?
  status      String
  clubId      String?
  date        DateTime @default(now())
  isAnonymous Boolean  @default(false)
  message     String?
  orderId     String?  @unique
  projectId   String?
  club        Club?    @relation(fields: [clubId], references: [id])
  order       Order?   @relation(fields: [orderId], references: [id])
  project     Project? @relation(fields: [projectId], references: [id])
}

model Setting {
  id        String   @id @default(uuid())
  key       String
  value     String
  clubId    String?
  updatedAt DateTime @updatedAt
  club      Club?    @relation(fields: [clubId], references: [id])

  @@unique([key, clubId])
}

model ContentSection {
  id        String   @id @default(uuid())
  page      String
  section   String
  content   String
  clubId    String?
  updatedAt DateTime @updatedAt
  club      Club?    @relation(fields: [clubId], references: [id])

  @@unique([page, section, clubId])
}

model Publication {
  id          String   @id @default(uuid())
  title       String
  content     String
  platform    String?
  status      String   @default("draft")
  publishDate DateTime
  mediaUrl    String?
  aiGenerated Boolean  @default(false)
  clubId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  club        Club     @relation(fields: [clubId], references: [id])
}

model CalendarEvent {
  id          String    @id @default(uuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  location    String?
  type        String    @default("meeting")
  clubId      String
  createdAt   DateTime  @default(now())
  htmlContent String?
  image       String?
  images      String[]  @default([])
  metadata    Json?     @default("{}")
  club        Club      @relation(fields: [clubId], references: [id])
}

model KnowledgeSource {
  id        String   @id @default(uuid())
  title     String
  type      String
  content   String
  fileUrl   String?
  clubId    String?
  createdAt DateTime @default(now())
  club      Club?    @relation(fields: [clubId], references: [id])
}

model ClubMember {
  id          String   @id @default(uuid())
  name        String
  image       String?
  description String?
  isBoard     Boolean  @default(false)
  boardRole   String?
  clubId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  position    Int      @default(0)
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model ProductCategory {
  id        String    @id @default(uuid())
  name      String
  slug      String
  clubId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  club      Club      @relation(fields: [clubId], references: [id])

  @@unique([slug, clubId])
}

model Product {
  id               String           @id @default(uuid())
  name             String
  slug             String
  description      String
  price            Float
  currency         String           @default("USD")
  status           String           @default("active")
  images           String[]
  isDigital        Boolean          @default(false)
  shippingRequired Boolean          @default(false)
  clubId           String
  categoryId       String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  orderItems       OrderItem[]
  category         ProductCategory? @relation(fields: [categoryId], references: [id])
  club             Club             @relation(fields: [clubId], references: [id])
  variants         ProductVariant[]
}

model ProductVariant {
  id            String      @id @default(uuid())
  sku           String?
  attributes    String
  priceOverride Float?
  stock         Int         @default(0)
  productId     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id            String      @id @default(uuid())
  subtotal      Float
  shipping      Float       @default(0)
  tax           Float       @default(0)
  discount      Float       @default(0)
  total         Float
  currency      String      @default("USD")
  status        String      @default("pending")
  customerName  String?
  customerEmail String?
  customerPhone String?
  metadata      String?
  clubId        String
  userId        String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  donation      Donation?
  club          Club        @relation(fields: [clubId], references: [id])
  user          User?       @relation(fields: [userId], references: [id])
  items         OrderItem[]
  payments      Payment[]
}

model OrderItem {
  id        String          @id @default(uuid())
  type      String
  title     String
  qty       Int
  unitPrice Float
  total     Float
  orderId   String
  productId String?
  variantId String?
  metadata  String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product?        @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
}

model Payment {
  id                   String   @id @default(uuid())
  provider             String   @default("stripe")
  providerRef          String?
  status               String
  amount               Float
  currency             String
  rawPayload           String?
  orderId              String?
  clubId               String
  applicationFee       Float?   @default(0)
  netAmount            Float?
  isPlatformCollection Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  club                 Club     @relation(fields: [clubId], references: [id])
  order                Order?   @relation(fields: [orderId], references: [id])
}

model PaymentProviderConfig {
  id        String   @id @default(uuid())
  provider  String
  enabled   Boolean  @default(false)
  publicKey String?
  secretRef String?
  settings  String?
  clubId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  club      Club     @relation(fields: [clubId], references: [id])

  @@unique([provider, clubId])
}

model PayoutRequest {
  id          String   @id @default(uuid())
  amount      Float
  currency    String   @default("USD")
  status      String   @default("pending")
  bankDetails String?
  notes       String?
  clubId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  club        Club     @relation(fields: [clubId], references: [id])
}

model NotificationConfig {
  id          String   @id @default(uuid())
  type        String   @default("smtp")
  enabled     Boolean  @default(false)
  host        String?
  port        Int?
  user        String?
  password    String?
  fromName    String?
  fromEmail   String?
  apiKey      String?
  phoneNumber String?
  wsSession   String?
  clubId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([type, clubId])
}

model CommunicationTemplate {
  id        String   @id @default(uuid())
  name      String
  type      String   @default("email")
  subject   String?
  content   String
  clubId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model CommunicationLog {
  id        String   @id @default(uuid())
  type      String
  recipient String
  subject   String?
  content   String
  status    String   @default("sent")
  errorMsg  String?
  clubId    String
  sentById  String?
  createdAt DateTime @default(now())
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  sentBy    User?    @relation(fields: [sentById], references: [id])
}

model Testimonial {
  id        String    @id @default(uuid())
  name      String
  role      String
  text      String
  image     String?
  clubId    String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  club      Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model WhatsAppConfig {
  id             String    @id @default(uuid())
  clubId         String    @unique
  phoneNumberId  String
  wabaId         String
  accessToken    String
  verifyToken    String
  appId          String?
  enabled        Boolean   @default(true)
  lastVerifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  club           Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model WhatsAppContact {
  id              String               @id @default(uuid())
  clubId          String
  name            String
  phone           String
  email           String?
  tags            String[]
  source          String               @default("manual")
  status          String               @default("active")
  metadata        String?
  totalSent       Int                  @default(0)
  totalDelivered  Int                  @default(0)
  totalRead       Int                  @default(0)
  totalFailed     Int                  @default(0)
  optedOutAt      DateTime?
  leadId          String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  archivedAt      DateTime?            @db.Timestamptz(6)
  listMemberships ContactListMember[]
  club            Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  messageLogs     WhatsAppMessageLog[]

  @@unique([phone, clubId])
  @@index([clubId], map: "idx_wa_contact_club")
  @@index([phone], map: "idx_wa_contact_phone")
  @@index([status], map: "idx_wa_contact_status")
}

model WhatsAppContactList {
  id          String              @id @default(uuid())
  clubId      String
  name        String
  description String?
  color       String              @default("#3B82F6")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  members     ContactListMember[]
  campaigns   WhatsAppCampaign[]
  club        Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId], map: "idx_wa_list_club")
}

model ContactListMember {
  id        String              @id @default(uuid())
  listId    String
  contactId String
  addedAt   DateTime            @default(now())
  contact   WhatsAppContact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  list      WhatsAppContactList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, contactId])
  @@index([contactId], map: "idx_clmember_contact")
  @@index([listId], map: "idx_clmember_list")
}

model WhatsAppTemplate {
  id             String             @id @default(uuid())
  clubId         String
  name           String
  displayName    String
  category       String             @default("MARKETING")
  language       String             @default("es")
  status         String             @default("pending")
  headerType     String?
  headerContent  String?
  bodyText       String
  footerText     String?
  buttons        String?
  metaTemplateId String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  campaigns      WhatsAppCampaign[]
  club           Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId], map: "idx_wa_template_club")
  @@index([status], map: "idx_wa_template_status")
}

model WhatsAppCampaign {
  id            String               @id @default(uuid())
  clubId        String
  name          String
  description   String?
  listId        String?
  templateId    String?
  templateVars  String?
  status        String               @default("draft")
  scheduledAt   DateTime?
  sentAt        DateTime?
  totalContacts Int                  @default(0)
  sent          Int                  @default(0)
  delivered     Int                  @default(0)
  read          Int                  @default(0)
  failed        Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  club          Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  list          WhatsAppContactList? @relation(fields: [listId], references: [id])
  template      WhatsAppTemplate?    @relation(fields: [templateId], references: [id])
  messageLogs   WhatsAppMessageLog[]

  @@index([clubId], map: "idx_wa_campaign_club")
  @@index([status], map: "idx_wa_campaign_status")
}

model WhatsAppMessageLog {
  id           String            @id @default(uuid())
  clubId       String
  campaignId   String?
  contactId    String?
  phone        String
  messageId    String?
  templateName String?
  bodyText     String?
  status       String            @default("pending")
  errorCode    String?
  errorMessage String?
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failedAt     DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  direction    String            @default("outgoing")
  campaign     WhatsAppCampaign? @relation(fields: [campaignId], references: [id])
  contact      WhatsAppContact?  @relation(fields: [contactId], references: [id])

  @@index([messageId])
  @@index([campaignId, status])
  @@index([campaignId, status], map: "idx_wa_msglog_campaign")
  @@index([clubId], map: "idx_wa_msglog_club")
  @@index([messageId], map: "idx_wa_msglog_messageid")
}

model PlatformConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Agent {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId       String?   @db.Uuid
  name         String    @db.VarChar(100)
  role         String    @db.VarChar(200)
  category     String?   @db.VarChar(50)
  description  String?
  systemPrompt String?
  aiModel      String?   @default("gpt-4") @db.VarChar(50)
  avatarSeed   String?   @db.VarChar(50)
  avatarColor  String?   @db.VarChar(20)
  capabilities String[]
  active       Boolean?  @default(true)
  order        Int?      @default(0)
  greeting     String?
  createdAt    DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @db.Timestamptz(6)

  @@index([clubId, order])
  @@index([clubId, order], map: "idx_agent_club")
}

model SponsoredClub {
  id             String                 @id @default(uuid())
  clubId         String
  type           String
  name           String
  foundationDate DateTime?
  meetingInfo    String?
  description    String?
  logo           String?
  facebookUrl    String?
  instagramUrl   String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  club           Club                   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  members        SponsoredClubMember[]
  projects       SponsoredClubProject[]

  @@unique([clubId, type])
}

model SponsoredClubMember {
  id              String        @id @default(uuid())
  sponsoredClubId String
  name            String
  role            String?
  email           String?
  phone           String?
  birthDate       DateTime?
  image           String?
  isBoard         Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sponsoredClub   SponsoredClub @relation(fields: [sponsoredClubId], references: [id], onDelete: Cascade)
}

model SponsoredClubProject {
  id              String        @id @default(uuid())
  sponsoredClubId String
  title           String
  description     String
  date            DateTime?
  image           String?
  images          String[]
  status          String        @default("completed")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sponsoredClub   SponsoredClub @relation(fields: [sponsoredClubId], references: [id], onDelete: Cascade)
}

model ExchangeStudent {
  id              String               @id @default(uuid())
  clubId          String
  type            String
  name            String
  email           String?
  phone           String?
  country         String?
  sponsorClubName String?
  academicYear    String?
  status          String               @default("active")
  image           String?
  counselorName   String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  hostFamilies    ExchangeHostFamily[]
  club            Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model ExchangeHostFamily {
  id         String           @id @default(uuid())
  clubId     String
  familyName String
  address    String?
  phone      String?
  email      String?
  studentId  String?
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  club       Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  student    ExchangeStudent? @relation(fields: [studentId], references: [id])
}

model NgseParticipant {
  id              String           @id @default(uuid())
  clubId          String
  type            String
  name            String
  email           String?
  phone           String?
  country         String?
  sponsorClubName String?
  profession      String?
  serviceArea     String?
  status          String           @default("active")
  image           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  hostFamilies    NgseHostFamily[]
  club            Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model NgseHostFamily {
  id            String           @id @default(uuid())
  clubId        String
  familyName    String
  address       String?
  phone         String?
  email         String?
  participantId String?
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  club          Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  participant   NgseParticipant? @relation(fields: [participantId], references: [id])
}

model RotexMember {
  id              String   @id @default(uuid())
  clubId          String
  name            String
  email           String?
  phone           String?
  exchangeYear    String?
  exchangeCountry String?
  role            String   @default("member")
  status          String   @default("active")
  image           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model FinancialReport {
  id          String   @id @default(uuid())
  clubId      String
  year        String
  title       String
  documentUrl String
  category    String
  status      String   @default("public")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model AgentActivity {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId   String    @db.Uuid
  agentName String?   @db.VarChar(100)
  userId    String    @db.Uuid
  clubId    String?   @db.Uuid
  action    String    @db.VarChar(80)
  tool      String?   @db.VarChar(80)
  details   Json?     @default("{}")
  success   Boolean?  @default(true)
  createdAt DateTime? @default(now()) @db.Timestamptz(6)

  @@index([agentId, createdAt(sort: Desc)], map: "idx_activity_agent")
  @@index([clubId, createdAt(sort: Desc)], map: "idx_activity_club")
}

model AgentConversation {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId      String    @db.Uuid
  userId       String    @db.Uuid
  clubId       String?   @db.Uuid
  title        String?   @db.VarChar(200)
  messages     Json?     @default("[]")
  messageCount Int?      @default(0)
  lastMessage  String?
  createdAt    DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @db.Timestamptz(6)

  @@index([clubId, updatedAt(sort: Desc)], map: "idx_conv_club")
  @@index([userId, agentId, updatedAt(sort: Desc)], map: "idx_conv_user_agent")
}

model AgentMessage {
  id             Int       @id @default(autoincrement())
  conversationId String?   @db.VarChar(60)
  role           String?   @db.VarChar(20)
  text           String?
  createdAt      DateTime? @default(now()) @db.Timestamptz(6)
}

model WhatsAppCustomField {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  clubId    String
  label     String   @db.VarChar(100)
  key       String   @db.VarChar(100)
  type      String   @default("text") @db.VarChar(30)
  required  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  Club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([clubId, key])
}

model FundingOpportunity {
  id            String    @id @default(uuid())
  title         String
  description   String
  matchCategory String?
  sourceUrl     String?
  sourceName    String?
  deadline      DateTime?
  amount        Float?
  status        String    @default("backlog")
  priority      String    @default("Medium")
  details       Json?     @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  clubId        String?
  agentId       String?   @default("rafael")
  metadata      Json?
  club          Club?     @relation(fields: [clubId], references: [id])
}

model SocialAccount {
  id             String          @id @default(uuid())
  clubId         String?
  platform       String
  platformId     String
  accountName    String?
  accessToken    String
  refreshToken   String?
  expiresAt      DateTime?
  avatar         String?
  status         String          @default("active")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  scheduledPosts ScheduledPost[]
  club           Club?           @relation(fields: [clubId], references: [id])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  firstName String
  lastName  String
  email     String
  phone     String?
  country   String?
  rating    Int      @default(5)
  text      String
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model VideoProject {
  id              String          @id @default(uuid())
  title           String
  videoUrl        String?
  sourceImages    Json
  config          Json
  status          String          @default("draft")
  kieJobId        String?
  clubId          String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  lastKieResponse Json?
  scheduledPosts  ScheduledPost[]
}

model ScheduledPost {
  id              String        @id @default(uuid())
  projectId       String
  socialAccountId String
  caption         String?
  status          String        @default("pending")
  scheduledFor    DateTime?
  publishedAt     DateTime?
  platformPostId  String?
  error           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  video           VideoProject  @relation(fields: [projectId], references: [id])
  account         SocialAccount @relation(fields: [socialAccountId], references: [id])
}

model Lead {
  id        String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  clubId    String?
  name      String    @db.VarChar(255)
  email     String    @db.VarChar(255)
  phone     String?   @db.VarChar(50)
  subject   String?   @db.VarChar(255)
  message   String?
  source    String?   @default("contact_form") @db.VarChar(50)
  status    String?   @default("new") @db.VarChar(30)
  notes     String?
  metadata  Json?     @default("{}")
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @db.Timestamptz(6)
  Club      Club?     @relation(fields: [clubId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([clubId, createdAt(sort: Desc)], map: "idx_lead_club")
  @@index([status], map: "idx_lead_status")
}

model TechnicalRequest {
  id            String    @id @default(uuid())
  clubId        String
  type          String    @default("domain_transfer")
  status        String    @default("pending")
  subject       String
  description   String?
  details       Json?     @default("{}")
  amount        Float?
  paymentStatus String    @default("unpaid")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  club          Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
}
