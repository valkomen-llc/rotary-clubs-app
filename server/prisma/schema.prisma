generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   // administrator (super_admin), club_admin, member
  clubId    String?
  club      Club?    @relation(fields: [clubId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Club {
  id          String   @id @default(uuid())
  name        String
  city        String?
  country     String?
  district    String?
  domain      String?  @unique
  subdomain   String?  @unique
  logo          String?
  footerLogo    String?
  endPolioLogo  String?
  description   String?
  status      String   @default("active") // active, inactive
  users       User[]
  projects    Project[]
  posts       Post[]
  donations   Donation[]
  settings    Setting[]
  content     ContentSection[]
  publications Publication[]
  events       CalendarEvent[]
  knowledge    KnowledgeSource[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Media {
  id        String   @id @default(uuid())
  filename  String
  url       String
  type      String   // image, document
  size      Int
  bucket    String?
  region    String?
  s3Key     String?  // The path inside the bucket
  clubId    String?
  createdAt DateTime @default(now())
}

model Project {
  id              String   @id @default(uuid())
  title           String
  description     String   @db.Text
  image           String?
  status          String   // active, completed, planned
  category        String?
  meta            Float?   @default(0)
  recaudado       Float?   @default(0)
  donantes        Int?     @default(0)
  beneficiarios   Int?     @default(0)
  ubicacion       String?
  fechaEstimada   DateTime?
  videoUrl        String?
  images          String[]  // Multiple image gallery
  impacto         String?   @db.Text
  actualizaciones String?   @db.Text
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Post {
  id             String   @id @default(uuid())
  title          String
  content        String   @db.Text
  image          String?
  published      Boolean  @default(false)
  category       String?
  tags           String[]
  keywords       String?
  seoTitle       String?
  seoDescription String?  @db.Text
  videoUrl       String?
  images         String[] // Gallery images
  isAI           Boolean  @default(false)
  clubId         String?
  club           Club?    @relation(fields: [clubId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Donation {
  id          String   @id @default(uuid())
  amount      Float
  currency    String   @default("USD")
  donorName   String?
  donorEmail  String?
  status      String   // pending, success, failed
  clubId      String?
  club        Club?    @relation(fields: [clubId], references: [id])
  date        DateTime @default(now())
}

model Setting {
  id        String   @id @default(uuid())
  key       String   
  value     String   @db.Text
  clubId    String?
  club      Club?    @relation(fields: [clubId], references: [id])
  updatedAt DateTime @updatedAt

  @@unique([key, clubId])
}

model ContentSection {
  id        String   @id @default(uuid())
  page      String   // home, about, etc.
  section   String   // hero, foundation, etc.
  content   String   @db.Text // JSON string with the section content
  clubId    String?
  club      Club?    @relation(fields: [clubId], references: [id])
  updatedAt DateTime @updatedAt

  @@unique([page, section, clubId])
}

model Publication {
  id          String   @id @default(uuid())
  title       String
  content     String   @db.Text
  platform    String?  // Instagram, Facebook, LinkedIn
  status      String   @default("draft") // draft, scheduled, published
  publishDate DateTime
  mediaUrl    String?
  aiGenerated Boolean  @default(false)
  clubId      String
  club        Club     @relation(fields: [clubId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CalendarEvent {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  startDate   DateTime
  endDate     DateTime?
  location    String?
  type        String   @default("meeting") // meeting, project, social, rotary_date
  clubId      String
  club        Club     @relation(fields: [clubId], references: [id])
  createdAt   DateTime @default(now())
}

model KnowledgeSource {
  id        String   @id @default(uuid())
  title     String
  type      String   // pdf, text, presentation
  content   String   @db.Text // Extracted text for the AI
  fileUrl   String?
  clubId    String?  // Null for global Rotary documents
  club      Club?    @relation(fields: [clubId], references: [id])
  createdAt DateTime @default(now())
}
