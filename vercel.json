{
  "version": 2,
  "buildCommand": "npx prisma generate --schema=./server/prisma/schema.prisma && vite build",
  "installCommand": "npm install",
  "framework": "vite",
  "nodeVersion": "20.x",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}